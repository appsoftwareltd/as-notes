{
    "name": "as-notes",
    "displayName": "AS Notes - Personal Knowledge Management",
    "description": "Navigate markdown files using [[wikilinks]]. Highlights links, Ctrl+Click navigation, hover tooltips, auto-create missing pages, rename sync, autocomplete, and alias support.",
    "version": "1.0.5",
    "publisher": "appsoftwareltd",
    "license": "MIT",
    "icon": "images/icon.png",
    "homepage": "https://github.com/appsoftwareltd/as-notes",
    "repository": {
        "type": "git",
        "url": "https://github.com/appsoftwareltd/as-notes.git"
    },
    "bugs": {
        "url": "https://github.com/appsoftwareltd/as-notes/issues"
    },
    "keywords": [
        "markdown",
        "wikilink",
        "notes",
        "wiki",
        "links",
        "personal knowledge management",
        "pkm",
        "obsidian"
    ],
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "galleryBanner": {
        "color": "#1e1e2e",
        "theme": "dark"
    },
    "activationEvents": [
        "onLanguage:markdown"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "markdown",
                "extensions": [
                    ".md",
                    ".markdown"
                ]
            }
        ],
        "commands": [
            {
                "command": "as-notes.initWorkspace",
                "title": "AS Notes: Initialise Workspace"
            },
            {
                "command": "as-notes.rebuildIndex",
                "title": "AS Notes: Rebuild Index"
            },
            {
                "command": "as-notes.toggleTodo",
                "title": "AS Notes: Toggle Todo"
            },
            {
                "command": "as-notes.toggleTaskPanel",
                "title": "AS Notes: Toggle Task Panel"
            },
            {
                "command": "as-notes.toggleShowTodoOnly",
                "title": "AS Notes: Toggle Show TODO Only",
                "icon": "$(filter)"
            },
            {
                "command": "as-notes.toggleTaskFromPanel",
                "title": "AS Notes: Toggle Task",
                "icon": "$(check)"
            },
            {
                "command": "as-notes.showBacklinks",
                "title": "AS Notes: Show Backlinks",
                "icon": "$(references)"
            }
        ],
        "keybindings": [
            {
                "command": "as-notes.toggleTodo",
                "key": "ctrl+shift+enter",
                "mac": "cmd+shift+enter",
                "when": "editorLangId == markdown"
            },
            {
                "command": "as-notes.toggleTaskPanel",
                "key": "ctrl+alt+t",
                "mac": "cmd+alt+t",
                "when": "as-notes.fullMode"
            },
            {
                "command": "as-notes.showBacklinks",
                "key": "ctrl+alt+b",
                "mac": "cmd+alt+b",
                "when": "as-notes.fullMode"
            }
        ],
        "configuration": {
            "title": "AS Notes",
            "properties": {
                "as-notes.periodicScanInterval": {
                    "type": "number",
                    "default": 300,
                    "minimum": 30,
                    "description": "Interval in seconds between automatic background scans for file changes. Set to 0 to disable periodic scanning."
                }
            }
        },
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./media/wikilink-preview.css"
        ],
        "views": {
            "explorer": [
                {
                    "id": "as-notes-tasks",
                    "name": "AS Notes Tasks",
                    "when": "as-notes.fullMode"
                }
            ]
        },
        "menus": {
            "editor/title": [
                {
                    "command": "as-notes.showBacklinks",
                    "when": "as-notes.fullMode && editorLangId == markdown",
                    "group": "navigation"
                }
            ],
            "view/title": [
                {
                    "command": "as-notes.toggleShowTodoOnly",
                    "when": "view == as-notes-tasks",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "as-notes.toggleTaskFromPanel",
                    "when": "view == as-notes-tasks && viewItem == taskItem",
                    "group": "inline"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "node build.mjs",
        "watch": "node build.mjs --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/sql.js": "^1.4.9",
        "@types/vscode": "^1.85.0",
        "esbuild": "^0.24.0",
        "markdown-it": "^14.1.1",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "sql.js": "^1.14.0"
    }
}