{
    "name": "as-notes",
    "displayName": "AS Notes - Personal Knowledge Management System (PKMS)",
    "description": "VS Code Personal Knowledge Management System (PKMS) - Markdown Editing, Wikilinks (inc. Nested), Tasks, Kanban, Files, Publish to HTML, Daily Journal, Encrypted Notes",
    "version": "2.2.4",
    "publisher": "appsoftwareltd",
    "license": "Elastic-2.0",
    "icon": "images/icon.png",
    "homepage": "https://github.com/appsoftwareltd/as-notes",
    "repository": {
        "type": "git",
        "url": "https://github.com/appsoftwareltd/as-notes.git"
    },
    "bugs": {
        "url": "https://github.com/appsoftwareltd/as-notes/issues"
    },
    "keywords": [
        "markdown",
        "wikilink",
        "notes",
        "wiki",
        "links",
        "personal knowledge management",
        "pkm",
        "obsidian"
    ],
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "galleryBanner": {
        "color": "#1e1e2e",
        "theme": "dark"
    },
    "activationEvents": [
        "onLanguage:markdown"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "markdown",
                "extensions": [
                    ".md",
                    ".markdown"
                ]
            }
        ],
        "commands": [
            {
                "command": "as-notes.initWorkspace",
                "title": "AS Notes: Initialise Workspace"
            },
            {
                "command": "as-notes.rebuildIndex",
                "title": "AS Notes: Rebuild Index"
            },
            {
                "command": "as-notes.toggleTaskPanel",
                "title": "AS Notes: Toggle Task Panel"
            },
            {
                "command": "as-notes.showBacklinks",
                "title": "AS Notes: Show Backlinks",
                "icon": "$(references)"
            },
            {
                "command": "as-notes.viewBacklinks",
                "title": "AS Notes: View Backlinks"
            },
            {
                "command": "as-notes.viewBacklinksForPage",
                "title": "AS Notes: View Backlinks for Page"
            },
            {
                "command": "as-notes.navigateToPage",
                "title": "AS Notes: Navigate to Page"
            },
            {
                "command": "as-notes.openDailyJournal",
                "title": "AS Notes: Open Daily Journal"
            },
            {
                "command": "as-notes.renameJournalFiles",
                "title": "AS Notes: DANGER (Back up first): Rename 'YYYY_MM_DD.md' journal files to 'YYYY-MM-DD.md' format"
            },
            {
                "command": "as-notes.setEncryptionKey",
                "title": "AS Notes: Set Encryption Key"
            },
            {
                "command": "as-notes.clearEncryptionKey",
                "title": "AS Notes: Clear Encryption Key"
            },
            {
                "command": "as-notes.encryptNotes",
                "title": "AS Notes: Encrypt All Notes"
            },
            {
                "command": "as-notes.decryptNotes",
                "title": "AS Notes: Decrypt All Notes"
            },
            {
                "command": "as-notes.createNote",
                "title": "AS Notes: Create Note"
            },
            {
                "command": "as-notes.createEncryptedFile",
                "title": "AS Notes: Create Encrypted Note"
            },
            {
                "command": "as-notes.createEncryptedJournalNote",
                "title": "AS Notes: Create Encrypted Journal Note"
            },
            {
                "command": "as-notes.encryptCurrentNote",
                "title": "AS Notes: Encrypt Current Note"
            },
            {
                "command": "as-notes.decryptCurrentNote",
                "title": "AS Notes: Decrypt Current Note"
            },
            {
                "command": "as-notes.cleanWorkspace",
                "title": "AS Notes: Clean Workspace"
            },
            {
                "command": "as-notes.toggleOutlinerMode",
                "title": "AS Notes: Toggle Outliner Mode"
            },
            {
                "command": "as-notes.openKanbanBoard",
                "title": "AS Notes: Open Kanban Board"
            },
            {
                "command": "as-notes.newKanbanCard",
                "title": "AS Notes: New Kanban Card"
            },
            {
                "command": "as-notes.selectKanbanBoard",
                "title": "AS Notes: Select Kanban Board"
            },
            {
                "command": "as-notes.createKanbanBoard",
                "title": "AS Notes: Create Kanban Board"
            },
            {
                "command": "as-notes.deleteKanbanBoard",
                "title": "AS Notes: Delete Kanban Board"
            },
            {
                "command": "as-notes.renameKanbanBoard",
                "title": "AS Notes: Rename Kanban Board"
            },
            {
                "command": "as-notes.convertTaskToKanbanCard",
                "title": "AS Notes: Convert Task to Kanban Card"
            },
            {
                "command": "as-notes.enterLicenceKey",
                "title": "AS Notes: Enter Licence Key"
            },
            {
                "command": "as-notes.insertTemplate",
                "title": "AS Notes: Insert Template"
            }
        ],
        "keybindings": [
            {
                "command": "as-notes.toggleTodo",
                "key": "ctrl+shift+enter",
                "mac": "cmd+shift+enter",
                "when": "editorLangId == markdown"
            },
            {
                "command": "as-notes.toggleTaskPanel",
                "key": "ctrl+alt+t",
                "mac": "cmd+alt+t",
                "when": "as-notes.fullMode"
            },
            {
                "command": "as-notes.showBacklinks",
                "key": "ctrl+alt+b",
                "mac": "cmd+alt+b",
                "when": "as-notes.fullMode"
            },
            {
                "command": "as-notes.openDailyJournal",
                "key": "ctrl+alt+j",
                "mac": "cmd+alt+j",
                "when": "as-notes.fullMode"
            },
            {
                "command": "as-notes.codeFenceEnter",
                "key": "enter",
                "when": "editorLangId == markdown && as-notes.onCodeFenceLine && !suggestWidgetVisible && editorHasSelection == false && !inlineSuggestionVisible"
            },
            {
                "command": "as-notes.outlinerEnter",
                "key": "enter",
                "when": "editorLangId == markdown && as-notes.outlinerMode && as-notes.onBulletLine && !suggestWidgetVisible && editorHasSelection == false && !inlineSuggestionVisible"
            },
            {
                "command": "as-notes.outlinerIndent",
                "key": "tab",
                "when": "editorLangId == markdown && as-notes.outlinerMode && as-notes.onBulletLine"
            },
            {
                "command": "as-notes.outlinerOutdent",
                "key": "shift+tab",
                "when": "editorLangId == markdown && as-notes.outlinerMode && as-notes.onBulletLine"
            },
            {
                "command": "as-notes.outlinerPaste",
                "key": "ctrl+v",
                "mac": "cmd+v",
                "when": "editorLangId == markdown && as-notes.outlinerMode && as-notes.onBulletLine && !editorReadonly"
            }
        ],
        "configuration": {
            "title": "AS Notes",
            "properties": {
                "as-notes.rootDirectory": {
                    "type": "string",
                    "default": "",
                    "scope": "resource",
                    "description": "Subdirectory for AS Notes within the workspace (e.g. 'docs' or 'notes'). When empty, the workspace root is used. All AS Notes data (.asnotes, journals, templates, etc.) lives within this directory. Configure this per workspace, not globally. Warning: if you change this after initialisation, you must manually move your notes directory to the new location."
                },
                "as-notes.periodicScanInterval": {
                    "type": "number",
                    "default": 300,
                    "minimum": 30,
                    "description": "Interval in seconds between automatic background scans for file changes. Set to 0 to disable periodic scanning."
                },
                "as-notes.journalFolder": {
                    "type": "string",
                    "default": "journals",
                    "description": "Folder for daily journal files, relative to the AS Notes root directory."
                },
                "as-notes.licenceKey": {
                    "type": "string",
                    "default": "",
                    "scope": "machine",
                    "description": "AS Notes Pro licence key (format: ASNO-XXXX-XXXX-XXXX-XXXX). Enter your licence key to activate Pro features. Purchase at https://www.asnotes.io/pricing"
                },
                "as-notes.assetPath": {
                    "type": "string",
                    "default": "assets/images",
                    "description": "Folder where dropped or pasted files are saved by VS Code's built-in markdown editor, relative to the AS Notes root directory. AS Notes configures the built-in markdown.copyFiles.destination setting to use this path."
                },
                "as-notes.enableLogging": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable diagnostic logging to .asnotes/logs/. Rolling 10 MB files, max 5. Requires reload after changing."
                },
                "as-notes.wikilinkColour": {
                    "type": "string",
                    "default": "",
                    "description": "Hex colour for wikilinks in the editor (e.g. #3794ff). Leave empty to use your theme's link colour."
                },
                "as-notes.backlinkGroupByChain": {
                    "type": "boolean",
                    "default": false,
                    "description": "Default backlink view mode. When true, backlinks are grouped by wikilink chain pattern. When false, backlinks are listed flat by page filename."
                },
                "as-notes.backlinkWrapContext": {
                    "type": "boolean",
                    "default": false,
                    "description": "Default context display in the backlinks panel. When false, context is compact (single line, truncated). When true, context wraps to show full text."
                },
                "as-notes.outlinerMode": {
                    "type": "boolean",
                    "default": false,
                    "scope": "window",
                    "description": "Enable Outliner Mode for markdown files. In outliner mode, Enter on a bullet line inserts a new bullet at the same indentation, Tab indents the bullet line, and Shift+Tab outdents it. Only applies to lines beginning with `- `."
                },
                "as-notes.kanbanAssetSizeWarningMB": {
                    "type": "number",
                    "default": 10,
                    "minimum": 0,
                    "description": "Warn when attaching files larger than this size (in MB) to a Kanban card. Set to 0 to disable the warning."
                },
                "as-notes.templateFolder": {
                    "type": "string",
                    "default": "templates",
                    "description": "Folder for note templates, relative to the AS Notes root directory. Templates are markdown files that can be inserted via the /Template slash command."
                },
                "as-notes.notesFolder": {
                    "type": "string",
                    "default": "notes",
                    "description": "Folder for new notes, relative to the AS Notes root directory. Used when creating pages via wikilink navigation and the Create Note / Create Encrypted Note commands."
                },
                "as-notes.createNotesInCurrentDirectory": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, new notes created via wikilink navigation are placed in the current editing file's directory instead of the notes folder. Ignored when the source file is in the journal folder."
                }
            }
        },
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./media/wikilink-preview.css"
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "as-notes-sidebar",
                    "title": "AS Notes",
                    "icon": "images/icon.svg"
                }
            ]
        },
        "views": {
            "as-notes-sidebar": [
                {
                    "type": "webview",
                    "id": "as-notes-search",
                    "name": "Search",
                    "initialSize": 1
                },
                {
                    "type": "webview",
                    "id": "as-notes-kanban",
                    "name": "Kanban"
                },
                {
                    "type": "webview",
                    "id": "as-notes-tasks",
                    "name": "Tasks"
                }
            ]
        },
        "menus": {
            "editor/title": [
                {
                    "command": "as-notes.showBacklinks",
                    "when": "as-notes.fullMode && editorLangId == markdown",
                    "group": "navigation"
                }
            ],
            "editor/title/context": [
                {
                    "command": "as-notes.showBacklinks",
                    "when": "as-notes.fullMode && resourceLangId == markdown",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "as-notes.navigateToPage",
                    "when": "as-notes.fullMode && editorLangId == markdown",
                    "group": "navigation"
                },
                {
                    "command": "as-notes.viewBacklinks",
                    "when": "as-notes.fullMode && editorLangId == markdown",
                    "group": "navigation"
                }
            ],
            "view/title": [],
            "view/item/context": [],
            "commandPalette": [
                {
                    "command": "as-notes.showBacklinks",
                    "when": "false"
                },
                {
                    "command": "as-notes.viewBacklinks",
                    "when": "false"
                },
                {
                    "command": "as-notes.viewBacklinksForPage",
                    "when": "false"
                },
                {
                    "command": "as-notes.navigateToPage",
                    "when": "false"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "node build.mjs",
        "watch": "node build.mjs --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "@types/node": "^20.11.0",
        "@types/sql.js": "^1.4.9",
        "@types/vscode": "^1.85.0",
        "as-notes-common": "file:../common",
        "esbuild": "^0.24.0",
        "markdown-it": "^14.1.1",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "dependencies": {
        "ignore": "^7.0.5",
        "sql.js": "^1.14.0",
        "yaml": "^2.7.1"
    }
}