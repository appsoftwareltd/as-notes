{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vs-code-extension",
                "--disable-extensions"
            ],
            "outFiles": [
                "${workspaceFolder}/vs-code-extension/dist/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}",
            "env": {
                "AS_NOTES_DEBUG": "1",
                // Uncomment to use test licence server
                // "AS_NOTES_LICENCE_SERVER_URL": "http://localhost:5173"
            }
        }
    ]
}